<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Centipedia — Evidence-Weighted Knowledge</title>
    <meta name="description" content="Centipedia is a deterministic, evidence-weighted knowledge synthesis system where humans submit evidence and AI compiles structured articles strictly from weighted sources.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Linux+Libertine:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="<%= root_path %>" class="site-logo">
          <span class="logo-icon">📖</span>
          <span class="logo-text">Centipedia</span>
        </a>
        <nav class="site-nav">
          <% if logged_in? %>
            <div class="user-badge">
              <img src="<%= current_user.avatar_display_url %>" alt="Avatar" class="nav-avatar">
              <span class="nav-handle">@<%= current_user.handle %></span>
            </div>
            <%= button_to "Log out", logout_path, method: :delete, class: "btn btn-subtle" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="site-content">
      <% if flash[:notice] %>
        <div class="flash flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash flash-alert"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>Centipedia — Evidence-compiled knowledge. Not AI-generated content.</p>
    </footer>
  </body>
</html>

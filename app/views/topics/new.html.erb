<div class="content-block">
  <h1>Create a New Topic</h1>
  <p class="subtitle">Define a subject for evidence-based synthesis.</p>

  <%= form_with model: @topic, class: "login-form" do |form| %>
    <% if @topic.errors.any? %>
      <div class="flash flash-alert">
        <ul>
          <% @topic.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :title, "Topic Title" %>
      <%= form.text_field :title, placeholder: "e.g., AI Alignment", required: true, class: "form-control" %>
      <small class="form-text">A concise, encyclopedic subject heading.</small>
    </div>

    <div class="form-group">
      <%= form.label :description, "Description" %>
      <%= form.text_area :description, placeholder: "A brief description of what this topic covers...", rows: 3, class: "form-control" %>
    </div>

    <%= form.submit "Create Topic", class: "btn btn-primary" %>
    <%= link_to "Cancel", topics_path, class: "btn btn-subtle" %>
  <% end %>
</div>
